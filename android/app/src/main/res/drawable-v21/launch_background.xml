<?xml version="1.0" encoding="utf-8"?>
<!-- Keep the window background white regardless of system dark/light mode.
     Flutter renders its own background so the Android window colour only
     shows for a single frame during startup; black here causes a visible
     black flash. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
</layer-list>
